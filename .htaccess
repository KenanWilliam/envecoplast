# 1. SERVER CONFIGURATION
Options +FollowSymLinks -Indexes
IndexIgnore *

# 2. CPANEL NODEJS HANDLER (Passenger)
PassengerEnabled on
PassengerAppType node
PassengerStartupFile app.js
PassengerAppRoot "REPLACE_ME_APP_ROOT"

# 3. STATIC FILES (Handled via symlinks in public_html)
# If Passenger is active, it handles everything by default.
# The symlinks in public_html allow Apache to serve static assets faster.
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /
</IfModule>

# 4. PERFORMANCE
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json image/svg+xml
</IfModule>
