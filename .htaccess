Options -Indexes

# This is for cPanel's Node.js handler (Passenger)
# If your cPanel username is different from what's below, you'll need to manually edit this on the server
PassengerEnabled on
PassengerAppType node
PassengerStartupFile server.js

<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Don't rewrite if it's a real file or directory
  RewriteCond %{REQUEST_FILENAME} !-f
  RewriteCond %{REQUEST_FILENAME} !-d

  # Proxy all requests to Node.js app on port 3000
  RewriteRule ^(.*)$ http://localhost:3000/$1 [P,L]
</IfModule>

<IfModule mod_proxy.c>
  ProxyPreserveHost On
</IfModule>
