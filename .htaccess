Options -Indexes

# 1. CPANEL NODEJS HANDLER (Passenger)
PassengerEnabled on
PassengerAppType node
PassengerStartupFile server.js
PassengerAppRoot "/home/dufoopqjnr/envecoplast.com"

# 2. STATIC ASSETS MAPPING
# Map /_next requests to the hidden .next folder so Apache can serve CSS/JS
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve the static files from the .next folder directly
  RewriteRule ^_next/(.*)$ .next/$1 [L]
  
  # If a file exists in public/, serve it
  RewriteCond %{DOCUMENT_ROOT}/public/$1 -f
  RewriteRule ^(.*)$ public/$1 [L]
</IfModule>
