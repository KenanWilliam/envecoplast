# 1. FORCE NODEJS EXECUTION
<Files "server.js">
  SetHandler application/x-httpd-php-source
</Files>

PassengerEnabled on
PassengerAppType node
PassengerStartupFile server.js
PassengerAppRoot "/home/dufoopqjnr/envecoplast.com"
PassengerBaseURI "/"

# 2. CORE SERVER SETTINGS
Options -Indexes
DirectoryIndex server.js

# 3. STATIC ASSETS & ROUTING
<IfModule mod_rewrite.c>
  RewriteEngine On

  # Map /_next/static requests to the physical .next/static folder
  RewriteRule ^_next/static/(.*)$ .next/static/$1 [L]

  # If the requested file exists in the public/ folder, serve it directly
  RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
  RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# 4. PERFORMANCE
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json image/svg+xml
</IfModule>
