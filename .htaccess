# 1. DISABLE DIRECTORY INDEXING
Options -Indexes

# 2. CPANEL NODEJS HANDLER (Passenger)
# These lines are required by cPanel to run Node.js
PassengerEnabled on
PassengerAppType node
PassengerStartupFile server.js
PassengerAppRoot "/home/dufoopqjnr/envecoplast"

# 3. STATIC FILES REDIRECT
# This allows styles and images to work
<IfModule mod_rewrite.c>
  RewriteEngine On
  RewriteBase /

  # Serve styles from .next folder
  RewriteRule ^_next/static/(.*)$ .next/static/$1 [L]
  
  # Serve images from public folder
  RewriteCond %{DOCUMENT_ROOT}/public%{REQUEST_URI} -f
  RewriteRule ^(.*)$ public/$1 [L]
</IfModule>

# 4. PERFORMANCE
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/html text/plain text/xml text/css text/javascript application/javascript application/x-javascript application/json image/svg+xml
</IfModule>
